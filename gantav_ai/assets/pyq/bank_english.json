    {"id":"bnk_e_04","question":"Identify error: (a) Each of the students (b) have submitted (c) their assignments (d) on time.","options":["a","b","c","d"],"correct_index":1,"explanation":"'Each' is singular → 'has submitted'.","topic":"Error Spotting","difficulty":"medium","year":2023},

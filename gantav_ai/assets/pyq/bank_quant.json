  "source": "IBPS/SBI PO quant pattern",
  "questions": [
    {"id":"bnk_q_01","question":"A sum becomes ₹7350 in 2 years and ₹8575 in 3 years at compound interest. Find the rate.","options":["10%","12.5%","15%","16.66%"],"correct_index":3,"explanation":"CI ratio 8575/7350 = 1.1666... → R ≈ 16.66%.","topic":"CI","difficulty":"hard","year":2022},
    {"id":"bnk_q_02","question":"If 15 men can finish work in 20 days, how many men to finish in 12 days?","options":["20","24","25","30"],"correct_index":2,"explanation":"15×20 = M×12 → M=25.","topic":"Time Work","difficulty":"easy","year":2021},
    {"id":"bnk_q_03","question":"A boat goes 20 km downstream in 4 hrs and returns in 5 hrs. Find speed of current.","options":["0.5","1","1.5","2"],"correct_index":0,"explanation":"Down=5, Up=4 km/hr → current=(5−4)/2=0.5.","topic":"Boats","difficulty":"medium","year":2020},
    {"id":"bnk_q_04","question":"Simplify: 25% of 800 + 40% of 250","options":["200","300","350","500"],"correct_index":1,"explanation":"200 + 100 = 300.","topic":"Percentage","difficulty":"easy","year":2023},
    {"id":"bnk_q_05","question":"Average of first 10 natural numbers is:","options":["5","5.5","6","6.5"],"correct_index":1,"explanation":"(1+…+10)/10 = 55/10 = 5.5.","topic":"Averages","difficulty":"easy","year":2019},
    {"id":"bnk_q_06","question":"Cost price of article is ₹400. If SP is ₹500, profit % is:","options":["15%","20%","25%","30%"],"correct_index":2,"explanation":"Profit=100; % = 100/400 ×100 = 25%.","topic":"Profit Loss","difficulty":"easy","year":2020},
    {"id":"bnk_q_07","question":"Train 200m long crosses a platform 300m long in 25 sec. Speed (km/hr)?","options":["60","72","80","90"],"correct_index":1,"explanation":"500/25=20 m/s ×3.6=72 km/hr.","topic":"TSD","difficulty":"medium","year":2022},
    {"id":"bnk_q_08","question":"A sum at SI becomes ₹1200 in 3 yrs and ₹1400 in 5 yrs. Principal = ?","options":["₹800","₹900","₹1000","₹1100"],"correct_index":1,"explanation":"2 yr interest=200 → 1 yr=100 → 3 yr SI=300 → P=1200−300=900.","topic":"SI","difficulty":"medium","year":2021},
    {"id":"bnk_q_09","question":"The ratio of three numbers is 3:4:5 and their sum is 60. Find the greatest.","options":["20","24","25","30"],"correct_index":2,"explanation":"3x+4x+5x=60 → x=5 → largest=25.","topic":"Ratio","difficulty":"easy","year":2023},
    {"id":"bnk_q_10","question":"Probability of getting a head in a fair coin toss:","options":["0","1/4","1/2","1"],"correct_index":2,"explanation":"1/2 by symmetry.","topic":"Probability","difficulty":"easy","year":2019},
    {"id":"bnk_q_11","question":"A shopkeeper sells at 10% profit. If CP increases by 20% and SP stays same, new profit % is:","options":["Loss 8.33%","Profit 8.33%","No profit/loss","Loss 10%"],"correct_index":0,"explanation":"CP=100→SP=110; new CP=120; profit %=(110-120)/120=-8.33%.","topic":"Profit Loss","difficulty":"hard","year":2024}
  ]
}
